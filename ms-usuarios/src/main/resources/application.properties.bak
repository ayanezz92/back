spring.application.name=ms-usuarios
server.port=8081

# Conexión flexible controlada por Docker (Si no detecta Docker, usa localhost)
spring.datasource.url=${SPRING_DATASOURCE_URL:jdbc:postgresql://localhost:5432/db_usuarios}
spring.datasource.username=${SPRING_DATASOURCE_USERNAME:postgres}
spring.datasource.password=${SPRING_DATASOURCE_PASSWORD:postgres} # <-- CAMBIADO DE adminpassword123 A VARIABLE

# Hibernate Settings
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.format_sql=true
spring.jpa.database-platform=org.hibernate.dialect.PostgreSQLDialect

# Enlace al contenedor del broker de RabbitMQ
spring.rabbitmq.host=${SPRING_RABBITMQ_HOST:localhost}
spring.rabbitmq.port=5672
spring.rabbitmq.username=guest
spring.rabbitmq.password=guest

# Activación del inicializador
spring.sql.init.mode=always
spring.sql.init.separator=//
spring.jpa.defer-datasource-initialization=true